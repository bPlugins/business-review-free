{
	"name": "business-review",
	"version": "1.0.0",
	"description": "Boost your website's credibility with B Testimonials Block, effortlessly showcasing customer ratings and reviews.",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"packages-update": "wp-scripts packages-update",
		"lint": "eslint src",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"format": "wp-scripts format",
		"start": "wp-scripts start --webpack-copy-php",
		"build": "wp-scripts build --webpack-copy-php",
		"i18n-pot": "wp i18n make-pot . languages/business-review.pot --exclude=\"src\" && cp ./languages/business-review.pot ./languages/business-review-en_US.po",
		"i18n-json": "wp i18n make-json languages/ --no-purge",
		"i18n-mo": "wp i18n make-mo languages/",
		"i18n": "npm run i18n-pot && npm run i18n-json && npm run i18n-mo",
		"find-ds": "find . -name '.DS_Store' -delete",
		"zip": "npm run find-ds && rm -f business-review.zip && zip -r business-review.zip index.php vendor readme.txt assets build languages -x '*.DS_Store'"
	},
	"dependencies": {
		"axios": "^1.2.0",
		"immer": "^9.0.17",
		"minimasonry": "^1.3.1",
		"react-router-dom": "^7.7.1",
		"react-toastify": "^9.1.1",
		"timeago.js": "^4.0.2"
	},
	"devDependencies": {
		"@wordpress/scripts": "^27.9.0",
		"eslint-webpack-plugin": "^4.2.0"
	}
}